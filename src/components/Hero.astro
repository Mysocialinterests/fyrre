---
const { title } = Astro.props;
---

<section class="section section-hero my-5! relative">
  <div class="container">
    <div class="relative">
      <img
        src="/img/banners/pexels-cottonbro-8088498.jpg"
        alt=""
        class="w-full h-[400px] object-cover"
      />
      <div class="absolute inset-0 bg-black/50 flex items-center px-10">
        <h1 class="text-white text-4xl md:text-6xl lg:text-8xl font-bold uppercase">
          {title}
        </h1>
      </div>
    </div>
  </div>
</section>