---
import Logo from "./Logo.astro";
import Socials from "./Socials.astro";

import { menu } from "../consts";
---

<header class="relative header px-4 z-10">
  <div class="container">
    <div
      class="py-4 border-b border-black flex flex-wrap gap-4 justify-between items-center"
    >
      <Logo />
      <nav class="hidden md:flex gap-x-6 gap-y-2 items-center ml-auto">
        {
          menu.map((link) => (
            <a class="hover:underline" href={link.url}>
              {link.title}
            </a>
          ))
        }
      </nav>
      <div class="hidden md:flex gap-4">
        &mdash;
        <Socials />
      </div>
      <div class="flex-none md:hidden">
        <label
          for="my-drawer-2"
          aria-label="open sidebar"
          class="btn btn-square btn-ghost"
        >
          <i class="fa-solid fa-bars"></i>
        </label>
      </div>
    </div>
  </div>
</header>
