---
import Layout from "../../../layouts/Base.astro";
import Hero from "../../../components/Hero.astro";
import { LOCALES } from "../../../i18n";

export const getStaticPaths = () =>
  Object.keys(LOCALES).map((lang) => ({
    params: { lang },
  }));
---

<Layout title="À propos — Mes Intérêts Sociaux">
  <Hero title="La Fondatrice" />

  <section class="section">
    <div class="container">
      <div class="max-w-3xl mx-auto py-10">
        <h2>Annick Bissainthe</h2>
        <p class="text-lg font-semibold my-6">
          Chercheuse en transfert de connaissances et fondatrice de Mes Intérêts Sociaux — une plateforme dédiée à rendre la science utile, compréhensible et accessible à tous.
        </p>
        <p class="my-4">
          L'information circule vite, mais rarement bien. Les algorithmes amplifient la colère. Les études scientifiques deviennent des armes dans les débats. Le savoir reste confiné dans les cercles académiques pendant que le public navigue seul dans le bruit.
        </p>
        <p class="my-4">
          Annick ne parachute pas des vérités absolues. Elle ouvre le capot : elle sélectionne des recherches publiques rigoureuses, décortique leur méthode, leurs forces et leurs limites — et les traduit en insights concrets pour le quotidien.
        </p>
        <p class="my-4">
          Ni journalisme d'opinion, ni vulgarisation superficielle. Une lecture honnête et