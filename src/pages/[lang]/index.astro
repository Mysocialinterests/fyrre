---
import Layout from "../../layouts/Base.astro";
import Hero from "../../components/Hero.astro";
import Topline from "../../components/Topline.astro";
import Demo from "../../components/DemoPost.astro";
import Posts from "../../components/Posts.astro";
import Podcasts from "../../components/Podcasts.astro";
import { LOCALES } from "../../i18n";
const locale = Astro.currentLocale;

export const getStaticPaths = () =>
  Object.keys(LOCALES).map((lang) => ({
    params: { lang },
  }));
---

<Layout title="Mes Intérêts Sociaux — Passer du bruit à la nuance">
  <Hero title="Passer du bruit à la nuance" />
  <Topline />
  <Demo />
  <Posts />
  <Podcasts />
</Layout>
